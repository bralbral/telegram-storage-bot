# Telegram Storage Bot Environment Variables
# Copy this file to .env and fill in your values

# Bot token from @BotFather (required)
BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Comma-separated list of admin Telegram IDs (required)
ADMIN_IDS=123456789,987654321

# Directory for downloaded files (optional, default: ./downloads)
DOWNLOAD_DIR=./downloads

# Database file path (optional, default: ./users.db)
DB_PATH=./users.db

# Maximum file size in bytes (optional, default: 2147483648 - 2GB)
MAX_FILE_SIZE=2147483648

# Throttle rate in seconds (optional, default: 3.0)
THROTTLE_RATE=3.0

# Maximum concurrent background tasks (optional, default: 3)
MAX_CONCURRENT_TASKS=3

# Health check server port (optional, default: 8080)
HEALTH_PORT=8080

# Use local Bot API server for large files (>20MB) (optional, default: false)
USE_LOCAL_API=false

# Local Bot API server URL (only used if USE_LOCAL_API=true)
LOCAL_API_URL=http://127.0.0.1:8081
