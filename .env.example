# Telegram Storage Bot Environment Variables
# Copy this file to .env and fill in your values

# Bot token from @BotFather (required)
BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Comma-separated list of admin Telegram IDs (required)
ADMIN_IDS=123456789,987654321

# Directory for downloaded files (optional, default: ./downloads)
DOWNLOAD_DIR=/downloads

# Database file path (optional, default: ./users.db)
DB_PATH=/app/data/users.db

# Maximum file size in bytes (optional, default: 2147483648 - 2GB)
MAX_FILE_SIZE=2147483648

# Throttle rate in seconds (optional, default: 3.0)
THROTTLE_RATE=3.0

# Per-user queue limits
MAX_BUFFER_FILES=100
MAX_BUFFER_SIZE=10737418240

# Number of Docker image pull/save jobs running simultaneously
MAX_DOCKER_OPERATIONS=1

# Logging level (optional, default: INFO)
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Health check server port (optional, default: 8080)
HEALTH_PORT=8080

# Telegram API credentials for local Bot API server (required for USE_LOCAL_API=true)
# Get these from https://my.telegram.org
TELEGRAM_API_ID=YOUR_TELEGRAM_API_ID
TELEGRAM_API_HASH=YOUR_TELEGRAM_API_HASH

# Use local Bot API server for large files (>20MB) (optional, default: true)
USE_LOCAL_API=true

# Local Bot API server URL (only used if USE_LOCAL_API=true)
LOCAL_API_URL=http://telegram-bot-api:8081
