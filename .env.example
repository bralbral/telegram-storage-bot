# Telegram Storage Bot Environment Variables
# Copy this file to .env and fill in your values

# Bot token from @BotFather (required)
BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Comma-separated list of admin Telegram IDs (required)
ADMIN_IDS=123456789,987654321

# Directory for downloaded files (optional, default: ./downloads)
DOWNLOAD_DIR=./downloads

# Use local Bot API server for large files (>20MB) (optional, default: false)
USE_LOCAL_API=false

# Local Bot API server URL (only used if USE_LOCAL_API=true)
LOCAL_API_URL=http://127.0.0.1:8081
